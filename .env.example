APP_NAME=catalog-service
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
APP_ROOT_PATH=/catalog
HOST=0.0.0.0
PORT=8002
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/db_catalog
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
LOG_LEVEL=INFO
LOG_FORMAT=json
